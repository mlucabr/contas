generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CHECKING
  SAVINGS
  INVESTMENT
  CASH
  RESERVE
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  INVESTMENT
  ADJUSTMENT
}

enum EntryStatus {
  PLANNED
  OPEN
  PAID
  RECEIVED
  CANCELED
}

enum Frequency {
  MONTHLY
  BIWEEKLY
  YEARLY
  CUSTOM
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accounts         Account[]
  cards            Card[]
  categories       Category[]
  transactions     Transaction[]
  recurringEntries RecurringEntry[]
  payables         Payable[]
  receivables      Receivable[]
  cardBills        CardBill[]
  installmentPlans InstallmentPlan[]
}

model Category {
  id               String            @id @default(cuid())
  userId           String
  name             String
  kind             TransactionType?
  createdAt        DateTime          @default(now())
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  recurringEntries RecurringEntry[]
  payables         Payable[]
  receivables      Receivable[]

  @@unique([userId, name])
  @@index([userId])
}

model Account {
  id             String       @id @default(cuid())
  userId         String
  name           String
  institution    String?
  type           AccountType
  includeInCash  Boolean      @default(true)
  openingBalance Decimal      @db.Decimal(14, 2)
  currentBalance Decimal      @db.Decimal(14, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  linkedCards    Card[]
  payables       Payable[]
  receivables    Receivable[]

  @@index([userId])
}

model Card {
  id               String            @id @default(cuid())
  userId           String
  name             String
  brand            String?
  creditLimit      Decimal           @db.Decimal(14, 2)
  closingDay       Int
  dueDay           Int
  linkedAccountId  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedAccount    Account?          @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)
  transactions     Transaction[]
  cardBills        CardBill[]
  installmentPlans InstallmentPlan[]

  @@index([userId])
}

model CardBill {
  id             String      @id @default(cuid())
  userId         String
  cardId         String
  referenceMonth DateTime
  dueDate        DateTime
  totalAmount    Decimal     @db.Decimal(14, 2)
  status         EntryStatus @default(OPEN)
  paidAt         DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  card           Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, referenceMonth])
  @@index([userId])
}

model Transaction {
  id                String           @id @default(cuid())
  userId            String
  accountId         String?
  cardId            String?
  categoryId        String?
  type              TransactionType
  description       String
  amount            Decimal          @db.Decimal(14, 2)
  transactionDate   DateTime
  isRecurringClone  Boolean          @default(false)
  installmentPlanId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account           Account?         @relation(fields: [accountId], references: [id], onDelete: SetNull)
  card              Card?            @relation(fields: [cardId], references: [id], onDelete: SetNull)
  category          Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  installmentPlan   InstallmentPlan? @relation(fields: [installmentPlanId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([transactionDate])
}

model RecurringEntry {
  id          String          @id @default(cuid())
  userId      String
  accountId   String?
  categoryId  String?
  type        TransactionType
  description String
  amount      Decimal         @db.Decimal(14, 2)
  frequency   Frequency
  dayOfMonth  Int?
  startDate   DateTime
  endDate     DateTime?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category    Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model InstallmentPlan {
  id               String        @id @default(cuid())
  userId           String
  cardId           String
  description      String
  totalAmount      Decimal       @db.Decimal(14, 2)
  installmentCount Int
  purchaseDate     DateTime
  firstBillMonth   DateTime
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  card             Card          @relation(fields: [cardId], references: [id], onDelete: Cascade)
  transactions     Transaction[]

  @@index([userId])
}

model Payable {
  id          String      @id @default(cuid())
  userId      String
  accountId   String?
  categoryId  String?
  description String
  amount      Decimal     @db.Decimal(14, 2)
  dueDate     DateTime
  status      EntryStatus @default(OPEN)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dueDate])
}

model Receivable {
  id          String      @id @default(cuid())
  userId      String
  accountId   String?
  categoryId  String?
  description String
  amount      Decimal     @db.Decimal(14, 2)
  dueDate     DateTime
  status      EntryStatus @default(OPEN)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dueDate])
}
